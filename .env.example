# Example VM IP only. Replace it with your own VM address before running services.
# If all middleware containers are in the same VM, keep the host part below consistent.
MALL_VM_HOST=192.168.56.101
MALL_NACOS_ADDR=192.168.56.101:8848
MALL_MYSQL_HOST=192.168.56.101
MALL_MYSQL_PORT=3306
# Local VM example credentials only. Use a least-privilege account and secrets manager/env vars outside local acceptance.
MALL_MYSQL_USERNAME=root
MALL_MYSQL_PASSWORD=root
MALL_REDIS_HOST=192.168.56.101
MALL_REDIS_PORT=6379
# Empty means no Redis password in the local VM example. Set this when Redis auth is enabled.
MALL_REDIS_PASSWORD=
MALL_ROCKETMQ_NAME_SERVER=192.168.56.101:9876
MALL_SENTINEL_DASHBOARD=192.168.56.101:8858
MALL_MILVUS_HOST=192.168.56.101
MALL_MILVUS_PORT=19530
MALL_AI_DEEPSEEK_API_KEY=replace-with-deepseek-api-key
MALL_AI_DEEPSEEK_BASE_URL=https://api.deepseek.com
MALL_AI_DEEPSEEK_CHAT_MODEL=deepseek-chat
MALL_AI_EMBEDDING_API_KEY=replace-with-embedding-api-key
MALL_AI_EMBEDDING_BASE_URL=https://api.openai.com
MALL_AI_EMBEDDING_MODEL=text-embedding-3-small
# Replace for any shared or deployed environment; do not reuse this placeholder as a real secret.
MALL_JWT_SECRET=replace-with-at-least-32-byte-secret
MALL_SECURITY_FAIL_ON_DEFAULT_SECRET=false
MALL_PAYMENT_CALLBACK_SECRET=replace-with-payment-callback-secret
MALL_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173

# Gateway Sentinel flow-control defaults. Tune these from capacity test results.
MALL_FLOW_AUTH_LOGIN_QPS=80
MALL_FLOW_AUTH_LOGIN_BURST=20
MALL_FLOW_PRODUCT_READ_QPS=600
MALL_FLOW_PRODUCT_READ_BURST=100
MALL_FLOW_SECKILL_CATALOG_QPS=500
MALL_FLOW_SECKILL_CATALOG_BURST=100
MALL_FLOW_SECKILL_TOKEN_QPS=200
MALL_FLOW_SECKILL_TOKEN_BURST=50
MALL_FLOW_SECKILL_SUBMIT_QPS=120
MALL_FLOW_SECKILL_SUBMIT_BURST=30
MALL_FLOW_ORDER_ROUTE_QPS=700
MALL_FLOW_ORDER_ROUTE_BURST=100
MALL_FLOW_PROMOTION_ROUTE_QPS=700
MALL_FLOW_PROMOTION_ROUTE_BURST=100
