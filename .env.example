# Example VM IP only. Replace it with your own VM address before running services.
# If all middleware containers are in the same VM, keep the host part below consistent.
MALL_VM_HOST=192.168.150.105
MALL_NACOS_ADDR=192.168.150.105:8848
MALL_MYSQL_HOST=192.168.150.105
MALL_MYSQL_PORT=3306
# Local VM example credentials only. Use a least-privilege account and secrets manager/env vars outside local acceptance.
MALL_MYSQL_USERNAME=root
MALL_MYSQL_PASSWORD=root
MALL_REDIS_HOST=192.168.150.105
MALL_REDIS_PORT=6379
# Empty means no Redis password in the local VM example. Set this when Redis auth is enabled.
MALL_REDIS_PASSWORD=
MALL_ROCKETMQ_NAME_SERVER=192.168.150.105:9876
MALL_SENTINEL_DASHBOARD=192.168.150.105:8858
# Replace for any shared or deployed environment; do not reuse this placeholder as a real secret.
MALL_JWT_SECRET=replace-with-at-least-32-byte-secret
MALL_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173
