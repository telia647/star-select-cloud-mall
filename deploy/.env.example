# Copy this file to .env in the VM deploy directory, then replace the VM IP.
# VM IP is environment-specific; do not commit your own .env file.
MALL_VM_HOST=192.168.56.101

# Local acceptance defaults only. Use stronger credentials in shared or deployed environments.
MALL_MYSQL_ROOT_PASSWORD=root
MALL_MYSQL_USERNAME=root
MALL_MYSQL_PASSWORD=root

# RocketMQ broker must advertise an address reachable from Windows/IDEA Java services.
# Keep empty to reuse MALL_VM_HOST.
MALL_ROCKETMQ_BROKER_IP=

# Sentinel Dashboard image is built from the official release jar.
SENTINEL_VERSION=1.8.9
# Build-time download mirror for VMs that cannot reach GitHub directly.
# Official source:
# https://github.com/alibaba/Sentinel/releases/download/1.8.9/sentinel-dashboard-1.8.9.jar
SENTINEL_DASHBOARD_JAR_URL=https://gh.llkk.cc/https://github.com/alibaba/Sentinel/releases/download/1.8.9/sentinel-dashboard-1.8.9.jar

# Used only by optional all-in-one app containers.
MALL_JWT_SECRET=replace-with-at-least-32-byte-secret-for-local
MALL_SECURITY_FAIL_ON_DEFAULT_SECRET=false
MALL_PAYMENT_CALLBACK_SECRET=replace-with-payment-callback-secret
MALL_SENTINEL_DASHBOARD=sentinel-dashboard:8858
MALL_MILVUS_HOST=milvus
MALL_MILVUS_PORT=19530

# Gateway Sentinel flow-control defaults for optional app containers.
MALL_FLOW_AUTH_LOGIN_QPS=80
MALL_FLOW_AUTH_LOGIN_BURST=20
MALL_FLOW_PRODUCT_READ_QPS=600
MALL_FLOW_PRODUCT_READ_BURST=100
MALL_FLOW_SECKILL_CATALOG_QPS=500
MALL_FLOW_SECKILL_CATALOG_BURST=100
MALL_FLOW_SECKILL_TOKEN_QPS=200
MALL_FLOW_SECKILL_TOKEN_BURST=50
MALL_FLOW_SECKILL_SUBMIT_QPS=120
MALL_FLOW_SECKILL_SUBMIT_BURST=30
MALL_FLOW_ORDER_ROUTE_QPS=700
MALL_FLOW_ORDER_ROUTE_BURST=100
MALL_FLOW_PROMOTION_ROUTE_QPS=700
MALL_FLOW_PROMOTION_ROUTE_BURST=100
